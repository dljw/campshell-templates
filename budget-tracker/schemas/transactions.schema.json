{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "budget-tracker/transactions.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "type", "description", "amount", "date", "sourceAccountId"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "enum": ["withdrawal", "deposit", "transfer"],
      "description": "Transaction type: withdrawal (expense), deposit (income), transfer (between accounts)"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Transaction description or memo"
    },
    "amount": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Transaction amount (always positive)"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Transaction date"
    },
    "sourceAccountId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$",
      "description": "Source account ID (the account money leaves)"
    },
    "destinationAccountId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$",
      "description": "Destination account ID (required for transfers)"
    },
    "categoryId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$",
      "description": "Category ID from the categories collection"
    },
    "tagIds": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]{2,36}$"
      },
      "maxItems": 10,
      "description": "Array of tag IDs"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    }
  },
  "additionalProperties": false
}
