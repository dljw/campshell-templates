{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "budget-tracker/accounts.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "name", "type", "currency"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Account display name"
    },
    "type": {
      "type": "string",
      "enum": ["asset", "expense", "revenue", "liability"],
      "description": "Account type following double-entry bookkeeping"
    },
    "subType": {
      "type": "string",
      "enum": ["checking", "savings", "cash", "credit-card", "loan", "investment", "mortgage", "other"],
      "description": "More specific account classification"
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "ISO 4217 currency code"
    },
    "balance": {
      "type": "number",
      "description": "Current account balance"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "active": {
      "type": "boolean",
      "description": "Whether the account is actively used"
    }
  },
  "additionalProperties": false
}
