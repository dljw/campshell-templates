{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "budget-tracker/tags.schema.json",
  "type": "object",
  "required": ["tags"],
  "properties": {
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]{2,36}$"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50,
            "description": "Tag name"
          },
          "color": {
            "type": "string",
            "enum": ["red", "orange", "yellow", "green", "blue", "purple", "gray"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
