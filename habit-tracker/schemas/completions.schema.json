{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "habit-tracker/completions.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "habitId", "date"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "habitId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$",
      "description": "Reference to the completed habit"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date the habit was completed (YYYY-MM-DD)"
    },
    "notes": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional notes about the completion"
    }
  },
  "additionalProperties": false
}
