{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "habit-tracker/categories.schema.json",
  "type": "object",
  "required": ["categories"],
  "properties": {
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]{2,36}$"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Category name"
          },
          "emoji": {
            "type": "string",
            "maxLength": 10,
            "description": "Emoji icon"
          },
          "color": {
            "type": "string",
            "enum": ["red", "orange", "yellow", "green", "blue", "purple", "pink", "gray"],
            "description": "Display color"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
