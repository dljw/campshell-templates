{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://campshell.dev/schemas/kanban/card.v1.json",
  "type": "object",
  "required": ["id", "title", "column", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{8,36}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "description": {
      "type": "string",
      "maxLength": 5000
    },
    "column": {
      "type": "string",
      "description": "ID of the column this card belongs to"
    },
    "labels": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 10
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    },
    "dueDate": {
      "type": "string",
      "format": "date"
    },
    "assignee": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "minimum": 0
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
