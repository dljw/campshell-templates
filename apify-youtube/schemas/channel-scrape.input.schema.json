{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-youtube/channel-scrape.input.schema.json",
  "type": "object",
  "required": ["channelUrls"],
  "properties": {
    "channelUrls": {
      "type": "array",
      "items": { "type": "string", "format": "uri", "minLength": 1 },
      "minItems": 1,
      "maxItems": 10,
      "description": "YouTube channel URLs (max 10 per call)"
    }
  },
  "additionalProperties": false
}
