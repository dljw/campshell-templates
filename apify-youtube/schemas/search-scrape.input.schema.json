{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-youtube/search-scrape.input.schema.json",
  "type": "object",
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Search query"
    },
    "maxResults": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 20,
      "description": "Max number of results to fetch"
    }
  },
  "additionalProperties": false
}
