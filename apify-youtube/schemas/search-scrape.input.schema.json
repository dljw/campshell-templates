{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-youtube/search-scrape.input.schema.json",
  "type": "object",
  "required": ["query"],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1,
      "description": "Search query"
    },
    "maxResults": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "default": 20,
      "description": "Max number of results to fetch (1-200)"
    },
    "uploadDate": {
      "type": "string",
      "enum": ["all", "hour", "today", "week", "month", "year"],
      "default": "all",
      "description": "Restrict results to a recent upload window"
    },
    "duration": {
      "type": "string",
      "enum": ["all", "short", "medium", "long"],
      "default": "all",
      "description": "Filter by video length"
    },
    "sortBy": {
      "type": "string",
      "enum": ["relevance", "date", "viewCount", "rating"],
      "default": "relevance",
      "description": "Sort order for results"
    },
    "proxyCountry": {
      "type": "string",
      "enum": ["", "US", "GB", "DE", "FR", "JP", "BR", "IN", "AU", "CA"],
      "default": "",
      "description": "Apify proxy country (empty = automatic)"
    }
  },
  "additionalProperties": false
}
