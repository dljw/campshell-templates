{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-youtube/videos-scrape.input.schema.json",
  "type": "object",
  "required": ["channelUrl"],
  "properties": {
    "channelUrl": {
      "type": "string",
      "format": "uri",
      "minLength": 1,
      "description": "YouTube channel URL"
    },
    "maxVideos": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 20,
      "description": "Max number of videos to fetch"
    }
  },
  "additionalProperties": false
}
