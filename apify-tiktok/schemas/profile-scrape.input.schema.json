{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-tiktok/profile-scrape.input.schema.json",
  "type": "object",
  "required": ["usernames"],
  "properties": {
    "usernames": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "maxItems": 50,
      "description": "TikTok usernames (no @, max 50 per call)"
    },
    "proxyCountry": {
      "type": "string",
      "enum": ["", "US", "GB", "DE", "FR", "JP", "BR", "IN", "AU", "CA"],
      "default": "",
      "description": "Apify proxy country (empty = automatic)"
    }
  },
  "additionalProperties": false
}
