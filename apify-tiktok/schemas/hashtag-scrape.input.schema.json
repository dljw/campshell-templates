{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-tiktok/hashtag-scrape.input.schema.json",
  "type": "object",
  "required": ["hashtag"],
  "properties": {
    "hashtag": {
      "type": "string",
      "minLength": 1,
      "description": "Hashtag without the # symbol"
    },
    "videosLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "default": 20,
      "description": "Max number of videos to fetch (1-200)"
    },
    "proxyCountry": {
      "type": "string",
      "enum": ["", "US", "GB", "DE", "FR", "JP", "BR", "IN", "AU", "CA"],
      "default": "",
      "description": "Apify proxy country (empty = automatic)"
    }
  },
  "additionalProperties": false
}
