{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "social-media/pillars.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "name": {
      "type": "string",
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "color": {
      "type": "string",
      "enum": ["red", "orange", "yellow", "green", "blue", "purple", "pink", "gray"]
    },
    "emoji": {
      "type": "string",
      "maxLength": 10
    },
    "targetMix": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Target percentage of content from this pillar"
    }
  },
  "additionalProperties": false
}
