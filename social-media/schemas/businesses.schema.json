{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "social-media/businesses.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "name": {
      "type": "string",
      "maxLength": 200
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "industry": {
      "type": "string",
      "maxLength": 200
    },
    "logoUrl": {
      "type": "string",
      "format": "uri"
    },
    "website": {
      "type": "string",
      "format": "uri"
    },
    "active": {
      "type": "boolean"
    },
    "notes": {
      "type": "string",
      "maxLength": 5000
    }
  },
  "additionalProperties": false
}
