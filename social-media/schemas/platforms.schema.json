{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "social-media/platforms.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "businessId", "platform"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "businessId": {
      "type": "string",
      "description": "Reference to a business"
    },
    "platform": {
      "type": "string",
      "enum": ["instagram", "tiktok", "linkedin", "youtube", "facebook", "lemon8"]
    },
    "active": {
      "type": "boolean"
    },
    "handle": {
      "type": "string",
      "maxLength": 100
    },
    "profileUrl": {
      "type": "string",
      "format": "uri"
    },
    "postsPerWeek": {
      "type": "integer",
      "minimum": 0,
      "maximum": 50
    },
    "bestTimes": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 7
    },
    "primaryFormats": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 10
    },
    "followers": {
      "type": "integer",
      "minimum": 0
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    }
  },
  "additionalProperties": false
}
