{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "social-media/posts.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "title", "businessId", "platform", "format", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "maxLength": 300
    },
    "businessId": {
      "type": "string",
      "description": "Reference to a business"
    },
    "scheduledAt": {
      "type": "string",
      "format": "date-time"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "platform": {
      "type": "string",
      "enum": ["instagram", "tiktok", "linkedin", "youtube", "facebook", "lemon8"]
    },
    "format": {
      "type": "string",
      "enum": ["reel", "carousel", "story", "static-image", "short-form-video", "long-form-video", "text-post", "article", "duet", "stitch", "mini-article", "tutorial", "list-post"]
    },
    "status": {
      "type": "string",
      "enum": ["idea", "drafting", "ready", "scheduled", "published", "archived"]
    },
    "pillarId": {
      "type": "string",
      "description": "Reference to a content pillar"
    },
    "campaignId": {
      "type": "string",
      "description": "Reference to a campaign"
    },
    "caption": {
      "type": "string",
      "maxLength": 5000
    },
    "hook": {
      "type": "string",
      "maxLength": 500
    },
    "cta": {
      "type": "string",
      "maxLength": 500
    },
    "hashtags": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 30
    },
    "contentTier": {
      "type": "string",
      "enum": ["hero", "hub", "hygiene"]
    },
    "assetUrl": {
      "type": "string",
      "format": "uri"
    },
    "crosspostOf": {
      "type": "string",
      "description": "Reference to the original post this was adapted from"
    },
    "notes": {
      "type": "string",
      "maxLength": 5000
    }
  },
  "additionalProperties": false
}
