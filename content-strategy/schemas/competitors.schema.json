{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-strategy/competitors.schema.json",
  "type": "object",
  "required": ["competitors"],
  "properties": {
    "competitors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "domain"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]{2,36}$"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "domain": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Competitor domain"
          },
          "estimatedTraffic": {
            "type": "integer",
            "minimum": 0,
            "description": "Estimated monthly organic traffic"
          },
          "topPages": {
            "type": "array",
            "maxItems": 20,
            "items": {
              "type": "object",
              "properties": {
                "url": { "type": "string" },
                "traffic": { "type": "integer", "minimum": 0 },
                "keywordsCount": { "type": "integer", "minimum": 0 }
              },
              "required": ["url", "traffic"],
              "additionalProperties": false
            },
            "description": "Top performing pages"
          },
          "contentThemes": {
            "type": "array",
            "maxItems": 20,
            "items": { "type": "string" },
            "description": "Main content themes"
          },
          "notes": {
            "type": "string",
            "maxLength": 2000,
            "description": "Analysis notes"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
