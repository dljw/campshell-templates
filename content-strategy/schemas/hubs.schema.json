{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-strategy/hubs.schema.json",
  "type": "object",
  "required": ["hubs"],
  "properties": {
    "hubs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]{2,36}$"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Hub name"
          },
          "description": {
            "type": "string",
            "maxLength": 500,
            "description": "Hub purpose and scope"
          },
          "pillarArticleId": {
            "type": "string",
            "pattern": "^[a-z0-9-]{2,36}$",
            "description": "Pillar article for this hub"
          },
          "color": {
            "type": "string",
            "enum": ["red", "orange", "yellow", "green", "blue", "purple", "pink", "gray"],
            "description": "Display color"
          },
          "status": {
            "type": "string",
            "enum": ["planning", "active", "complete"],
            "description": "Hub lifecycle status"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
