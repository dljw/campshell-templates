{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-strategy/articles.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "title", "slug", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300,
      "description": "Article title"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "URL slug, e.g. best-planner-apps"
    },
    "pageUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "Full page path, e.g. /blog/best-planner-apps/"
    },
    "status": {
      "type": "string",
      "enum": ["idea", "planned", "briefed", "drafting", "review", "published", "optimizing", "needs-refresh"],
      "description": "Content pipeline status"
    },
    "contentType": {
      "type": "string",
      "enum": ["pillar", "cluster", "standalone", "comparison", "update"],
      "description": "Role in content hub architecture"
    },
    "hubId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$",
      "description": "Reference to content hub"
    },
    "primaryKeyword": {
      "type": "string",
      "maxLength": 200,
      "description": "Main target keyword"
    },
    "wordCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Article word count"
    },
    "publishDate": {
      "type": "string",
      "format": "date",
      "description": "Actual publish date"
    },
    "scheduledDate": {
      "type": "string",
      "format": "date",
      "description": "Planned publish date"
    },
    "lastOptimized": {
      "type": "string",
      "format": "date",
      "description": "Date of last optimization pass"
    },
    "phase": {
      "type": "string",
      "enum": ["phase-1", "phase-2", "phase-3"],
      "description": "Content calendar phase"
    },
    "priority": {
      "type": "string",
      "enum": ["high", "medium", "low"],
      "description": "Publishing priority"
    },
    "filePath": {
      "type": "string",
      "maxLength": 500,
      "description": "Local file path to the article content (e.g., /Users/me/blog/posts/best-planner-apps.md)"
    },
    "domainId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$",
      "description": "Reference to domain"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Free-form notes"
    }
  },
  "additionalProperties": false
}
