{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-strategy/domains.schema.json",
  "type": "object",
  "required": ["domains"],
  "properties": {
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]{2,36}$"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Display name for this domain/project"
          },
          "domain": {
            "type": "string",
            "maxLength": 200,
            "description": "Domain name (e.g., doobies-app.com)"
          },
          "basePath": {
            "type": "string",
            "maxLength": 500,
            "description": "Local project root path (e.g., /Users/me/projects/my-blog)"
          },
          "isDefault": {
            "type": "boolean",
            "description": "Whether this is the default domain"
          },
          "articlesDir": {
            "type": "string",
            "maxLength": 500,
            "description": "Articles directory relative to basePath (e.g., content/blog/)"
          },
          "articleFormat": {
            "type": "object",
            "description": "Article structure template for this domain",
            "properties": {
              "name": {
                "type": "string",
                "maxLength": 100,
                "description": "Format name (e.g., Blog Post, Landing Page)"
              },
              "sections": {
                "type": "array",
                "maxItems": 20,
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": {
                      "type": "string",
                      "maxLength": 100
                    },
                    "description": {
                      "type": "string",
                      "maxLength": 500
                    },
                    "required": {
                      "type": "boolean"
                    },
                    "guidanceNotes": {
                      "type": "string",
                      "maxLength": 1000
                    }
                  },
                  "additionalProperties": false
                }
              },
              "defaultWordCount": {
                "type": "integer",
                "minimum": 0,
                "description": "Target word count for articles using this format"
              },
              "frontmatterFields": {
                "type": "array",
                "items": {
                  "type": "string",
                  "maxLength": 100
                },
                "maxItems": 20,
                "description": "Custom metadata fields for this domain's articles"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
