{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "content-strategy/cycles.schema.json",
  "type": "object",
  "required": ["id", "createdAt", "cycleDate", "periodStart", "periodEnd"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "cycleDate": {
      "type": "string",
      "format": "date",
      "description": "Date the analysis was run"
    },
    "periodStart": {
      "type": "string",
      "format": "date",
      "description": "GSC data range start"
    },
    "periodEnd": {
      "type": "string",
      "format": "date",
      "description": "GSC data range end"
    },
    "sitewide": {
      "type": "object",
      "properties": {
        "impressions": { "type": "integer", "minimum": 0 },
        "clicks": { "type": "integer", "minimum": 0 },
        "ctr": { "type": "number", "minimum": 0, "maximum": 100 },
        "avgPosition": { "type": "number", "minimum": 0, "maximum": 999 }
      },
      "required": ["impressions", "clicks", "ctr", "avgPosition"],
      "additionalProperties": false,
      "description": "Sitewide aggregate metrics"
    },
    "dailyTrend": {
      "type": "object",
      "properties": {
        "firstHalfAvg": { "type": "number", "minimum": 0 },
        "secondHalfAvg": { "type": "number", "minimum": 0 },
        "trajectory": { "type": "string", "enum": ["growing", "stable", "declining"] },
        "last7dAvg": { "type": "number", "minimum": 0 }
      },
      "required": ["firstHalfAvg", "secondHalfAvg", "trajectory", "last7dAvg"],
      "additionalProperties": false,
      "description": "Daily impression trend summary"
    },
    "quadrantCounts": {
      "type": "object",
      "properties": {
        "stars": { "type": "integer", "minimum": 0 },
        "quickWins": { "type": "integer", "minimum": 0 },
        "ctrOpportunities": { "type": "integer", "minimum": 0 },
        "longTermTargets": { "type": "integer", "minimum": 0 },
        "earlySignals": { "type": "integer", "minimum": 0 },
        "dogs": { "type": "integer", "minimum": 0 }
      },
      "required": ["stars", "quickWins", "ctrOpportunities", "longTermTargets", "earlySignals", "dogs"],
      "additionalProperties": false,
      "description": "Keyword distribution across quadrants"
    },
    "pageSnapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "pageUrl": { "type": "string" },
          "impressions": { "type": "integer", "minimum": 0 },
          "clicks": { "type": "integer", "minimum": 0 },
          "ctr": { "type": "number", "minimum": 0, "maximum": 100 },
          "position": { "type": "number", "minimum": 0, "maximum": 999 },
          "indexed": { "type": "boolean" }
        },
        "required": ["pageUrl", "impressions", "clicks", "ctr", "position"],
        "additionalProperties": false
      },
      "description": "Per-page GSC snapshot"
    },
    "querySnapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "impressions": { "type": "integer", "minimum": 0 },
          "clicks": { "type": "integer", "minimum": 0 },
          "position": { "type": "number", "minimum": 0, "maximum": 999 },
          "pageUrl": { "type": "string" }
        },
        "required": ["query", "impressions", "clicks", "position"],
        "additionalProperties": false
      },
      "description": "Per-query GSC snapshot"
    },
    "notIndexedPages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pages not yet indexed by Google"
    },
    "cannibalizationWarnings": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of cannibalization issues detected"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000,
      "description": "Cycle analysis notes"
    },
    "domainId": {
      "type": "string",
      "pattern": "^[a-z0-9-]{2,36}$",
      "description": "Reference to domain"
    }
  },
  "additionalProperties": false
}
