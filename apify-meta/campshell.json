{
  "name": "apify-meta",
  "type": "service",
  "version": "1.0.0",
  "displayName": "Meta Analytics",
  "description": "Read-only Facebook (Meta) analytics — pull page stats and recent posts via the Apify scraper",
  "author": { "name": "campshell" },
  "license": "MIT",
  "category": "social-media",
  "tags": ["social-media", "analytics", "scraping", "facebook", "meta"],
  "emoji": "👥",
  "dataDir": "data/apify-meta",
  "schemas": {
    "pages-scrape.input": "schemas/pages-scrape.input.schema.json",
    "pages-scrape.output": "schemas/pages-scrape.output.schema.json",
    "posts-scrape.input": "schemas/posts-scrape.input.schema.json",
    "posts-scrape.output": "schemas/posts-scrape.output.schema.json",
    "media-zip.input": "schemas/media-zip.input.schema.json",
    "media-zip.output": "schemas/media-zip.output.schema.json"
  },
  "storage": {
    "runs": {
      "pattern": "one-per-file",
      "directory": "runs",
      "fileNamePattern": "{id}.json"
    }
  },
  "operations": {
    "pages-scrape": {
      "description": "Scrape public Facebook page stats (followers, likes, category, about) for one or more page URLs",
      "inputSchema": "schemas/pages-scrape.input.schema.json",
      "outputSchema": "schemas/pages-scrape.output.schema.json",
      "handler": "handlers/pages-scrape",
      "timeout": 280000,
      "rateLimit": { "maxPerMinute": 5 }
    },
    "posts-scrape": {
      "description": "Scrape recent posts from a public Facebook page, with engagement counts",
      "inputSchema": "schemas/posts-scrape.input.schema.json",
      "outputSchema": "schemas/posts-scrape.output.schema.json",
      "handler": "handlers/posts-scrape",
      "timeout": 280000,
      "rateLimit": { "maxPerMinute": 5 }
    },
    "media-zip": {
      "description": "Bundle cached media files from a previous run into a ZIP for download",
      "inputSchema": "schemas/media-zip.input.schema.json",
      "outputSchema": "schemas/media-zip.output.schema.json",
      "handler": "handlers/media-zip",
      "timeout": 60000
    }
  },
  "secrets": [
    {
      "key": "APIFY_TOKEN",
      "label": "Apify API Token",
      "description": "Your Apify token from console.apify.com/account/integrations",
      "required": true,
      "sensitive": true
    }
  ],
  "ui": {
    "framework": "react",
    "entry": "index.tsx",
    "route": "/apify-meta"
  },
  "guide": "guide.json"
}
