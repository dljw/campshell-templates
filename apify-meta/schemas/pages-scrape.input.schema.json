{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-meta/pages-scrape.input.schema.json",
  "type": "object",
  "required": ["pageUrls"],
  "properties": {
    "pageUrls": {
      "type": "array",
      "items": { "type": "string", "format": "uri", "minLength": 1 },
      "minItems": 1,
      "maxItems": 50,
      "description": "Facebook page URLs (max 50 per call)"
    },
    "proxyCountry": {
      "type": "string",
      "enum": ["", "US", "GB", "DE", "FR", "JP", "BR", "IN", "AU", "CA"],
      "default": "",
      "description": "Apify proxy country (empty = automatic)"
    },
    "cacheMedia": {
      "type": "boolean",
      "default": true,
      "description": "Download profile picture and cover photo to local cache so historical runs render after Apify URLs expire."
    }
  },
  "additionalProperties": false
}
