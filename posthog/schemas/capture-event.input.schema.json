{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "posthog/capture-event.input.schema.json",
  "type": "object",
  "required": ["event", "distinctId"],
  "properties": {
    "event": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Event name to track"
    },
    "distinctId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique identifier for the user"
    },
    "properties": {
      "type": "object",
      "additionalProperties": true,
      "description": "Event properties as key/value pairs"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp; defaults to now"
    }
  },
  "additionalProperties": false
}
