{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-instagram/hashtag-scrape.input.schema.json",
  "type": "object",
  "required": ["hashtag"],
  "properties": {
    "hashtag": {
      "type": "string",
      "minLength": 1,
      "description": "Hashtag without the # symbol"
    },
    "postsLimit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50,
      "default": 20,
      "description": "Max number of posts to fetch"
    }
  },
  "additionalProperties": false
}
