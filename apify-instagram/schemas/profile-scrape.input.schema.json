{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-instagram/profile-scrape.input.schema.json",
  "type": "object",
  "required": ["usernames"],
  "properties": {
    "usernames": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "maxItems": 50,
      "description": "Instagram usernames (no @, max 50 per call)"
    },
    "proxyCountry": {
      "type": "string",
      "enum": ["", "US", "GB", "DE", "FR", "JP", "BR", "IN", "AU", "CA"],
      "default": "",
      "description": "Apify proxy country (empty = automatic). Use when scraping is geo-sensitive."
    },
    "cacheMedia": {
      "type": "boolean",
      "default": true,
      "description": "Download avatars + latest-post thumbnails to local cache. Recommended on — avatars are tiny and Instagram CDN URLs expire."
    }
  },
  "additionalProperties": false
}
