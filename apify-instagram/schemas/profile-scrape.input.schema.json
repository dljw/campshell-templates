{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "apify-instagram/profile-scrape.input.schema.json",
  "type": "object",
  "required": ["usernames"],
  "properties": {
    "usernames": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "maxItems": 10,
      "description": "Instagram usernames (no @, max 10 per call)"
    }
  },
  "additionalProperties": false
}
