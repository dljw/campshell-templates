{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dataforseo/keyword-suggestions.output.schema.json",
  "type": "object",
  "required": ["suggestions"],
  "properties": {
    "suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["keyword", "searchVolume", "cpc", "competition", "competitionLevel"],
        "properties": {
          "keyword": { "type": "string" },
          "searchVolume": { "type": "integer" },
          "cpc": { "type": "number" },
          "competition": { "type": "number" },
          "competitionLevel": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
