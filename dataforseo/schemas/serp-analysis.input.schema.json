{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dataforseo/serp-analysis.input.schema.json",
  "type": "object",
  "required": ["keyword"],
  "properties": {
    "keyword": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "description": "Keyword to analyze SERP for"
    },
    "locationCode": {
      "type": "integer",
      "default": 2840,
      "description": "DataForSEO location code"
    },
    "languageCode": {
      "type": "string",
      "default": "en",
      "description": "Language code for results"
    },
    "depth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 10,
      "description": "Number of SERP results to return"
    }
  },
  "additionalProperties": false
}
