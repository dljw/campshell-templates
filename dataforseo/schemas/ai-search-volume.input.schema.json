{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["keywords"],
  "properties": {
    "keywords": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "description": "Keywords to get AI platform search volume for",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 250
      }
    },
    "locationCode": {
      "type": "integer",
      "description": "Location code. Default: 2840 (United States)",
      "default": 2840
    },
    "languageCode": {
      "type": "string",
      "description": "Language code (e.g. en). Default: en",
      "default": "en"
    }
  },
  "additionalProperties": false
}
