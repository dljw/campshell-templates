{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "dataforseo/serp-analysis.output.schema.json",
  "type": "object",
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["position", "url", "title", "description", "domain"],
        "properties": {
          "position": { "type": "integer" },
          "url": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "domain": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
