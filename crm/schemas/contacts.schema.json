{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://campshell.dev/schemas/crm/contacts.v1.json",
  "type": "object",
  "required": ["id", "name", "createdAt"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]{8,36}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string",
      "maxLength": 50
    },
    "company": {
      "type": "string",
      "maxLength": 200
    },
    "notes": {
      "type": "string",
      "maxLength": 5000
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
