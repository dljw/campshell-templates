{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "seo-tracker/domains.schema.json",
  "type": "object",
  "required": ["domains"],
  "properties": {
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "createdAt", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]{2,36}$"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Display name for this domain/project"
          },
          "domain": {
            "type": "string",
            "maxLength": 200,
            "description": "Domain name (e.g., example.com)"
          },
          "basePath": {
            "type": "string",
            "maxLength": 500,
            "description": "Local project root path (e.g., /Users/me/projects/my-blog)"
          },
          "isDefault": {
            "type": "boolean",
            "description": "Whether this is the default domain"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
